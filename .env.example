# ---------------------------------------------------------------------------
# Tailscale container configuration — EXAMPLE
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored (it holds the secret auth key); this template is committed.
# Consumed by docker-compose.yaml via compose-helper.sh (--env-file .env).
# ---------------------------------------------------------------------------

# Auth key from https://login.tailscale.com/admin/settings/keys
# For unattended containers prefer a key that is reusable + pre-approved + tagged.
# Required — the container refuses to start without it.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Node name as it appears in the tailnet.
TS_HOSTNAME=home-tailscale-container

# Image tag. Pin to a specific version (e.g. v1.78.1) for reproducible deploys
# instead of chasing "latest".
TS_IMAGE_TAG=latest

# Where tailscaled persists state inside the container (mapped to the volume).
TS_STATE_DIR=/var/lib/tailscale

# Networking mode. true = userspace/netstack: no TUN device or NET_ADMIN needed,
# subnet router + exit node still work (lower throughput). false = kernel
# networking (requires the TUN device + NET_ADMIN + forwarding sysctls).
TS_USERSPACE=true

# Don't let the tailnet override this host's DNS resolver.
TS_ACCEPT_DNS=false

# Subnets this node advertises (subnet router). Approve them in the admin console.
# Leave empty for exit-node-only. Example below; replace with your own LAN CIDRs.
TS_ROUTES=192.168.0.0/24

# Extra tailscale up flags.
#   --advertise-exit-node : offer this node as an exit node
#   --accept-routes=false : don't pull in routes advertised by other nodes
TS_EXTRA_ARGS=--accept-routes=false --advertise-exit-node=true
